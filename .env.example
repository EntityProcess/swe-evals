# Copy to swe-evals/.env or export these in your shell before running.
#
# Select the actual coding-agent target from the repository root .agentv/targets.yaml.
# Common values: codex, pi, pi-sdk
AGENT_TARGET=codex

# Select an LLM grader target if you add LLM assertions later. The v1 harness uses
# deterministic code graders, but agent targets may still reference grader.
GRADER_TARGET=azure

# Optional Codex target settings.
CODEX_EXECUTABLE=codex
CODEX_MODEL=gpt-5-codex
CODEX_REASONING_EFFORT=medium
CODEX_WORKSPACE_DIR=
CODEX_LOG_DIR=.agentv/logs/codex

# Optional Pi/OpenRouter target settings.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5-codex

# Optional Azure grader settings.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_RESPONSES_BASE_URL=https://<resource>.openai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=
AZURE_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=v1

# Keep AgentV temp workspaces for inspection after a run.
AGENTV_KEEP_WORKSPACES=0
