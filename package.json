{
	"name": "swe-evals",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"metadata:check": "bun scripts/check-dayjs-metadata-drift.ts",
		"typecheck": "tsc --noEmit --skipLibCheck --allowImportingTsExtensions --moduleResolution bundler --module esnext --target es2022 --types bun agentv.config.ts scripts/*.ts",
		"lint": "biome check .",
		"eval:dry-run": "AGENT_TARGET=codex GRADER_TARGET=azure bun ../agentv/apps/cli/src/cli.ts eval evals/dayjs-v1.eval.yaml --dry-run --threshold 0"
	},
	"dependencies": {
		"@agentv/eval": "file:../agentv/packages/eval"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/bun": "^1.3.4",
		"@types/node": "^24.1.0",
		"typescript": "^5.8.3"
	}
}
